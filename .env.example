# LitVM DEX Environment Variables

# Network Configuration
VITE_NETWORK_NAME=LitVM
VITE_CHAIN_ID=175177
VITE_RPC_URL=https://rpc.litvm.io
VITE_EXPLORER_URL=https://explorer.litvm.io

# Contract Addresses (update after deployment)
VITE_DEX_CONTRACT_ADDRESS=
VITE_LIT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
VITE_USDT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000001
VITE_WETH_TOKEN_ADDRESS=0x0000000000000000000000000000000000000002
VITE_DAI_TOKEN_ADDRESS=0x0000000000000000000000000000000000000003

# Deployment Configuration (for deployment scripts only)
PRIVATE_KEY=
DEPLOYER_ADDRESS=

# API Keys (optional)
VITE_INFURA_KEY=
VITE_ALCHEMY_KEY=

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
